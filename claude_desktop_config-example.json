{
  "mcpServers": {
    "smartsheet": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "http://localhost:8787/sse",
        "--header",
        "SMARTSHEET_API_KEY: YOUR_SMARTSHEET_API_KEY",
        "--header",
        "SMARTSHEET_ENDPOINT: https://api.smartsheet.com/2.0"
      ]
    }
  }
}