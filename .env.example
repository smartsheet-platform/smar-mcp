# Smartsheet API token
# You can obtain a token from the Smartsheet Developer Portal: https://developers.smartsheet.com/
SMARTSHEET_API_KEY=your_smartsheet_api_token_here

# Smartsheet API Endpoint
# Choose the appropriate endpoint based on your Smartsheet deployment:
#
# - US Commercial:        https://api.smartsheet.com/2.0
# - EU:                   https://api.smartsheet.eu/2.0
# - US Gov (FedRAMP):     https://api.smartsheetgov.com/2.0
# - Test/Sandbox:         https://api.test.smartsheet.com/2.0
#
# For most users, use the US Commercial endpoint.
# If you're on a government-approved FedRAMP deployment, use the US Gov endpoint.
SMARTSHEET_ENDPOINT=https://api.smartsheet.com/2.0

# Control whether deletion operations are enabled (true/false)
# When not set or set to false, delete_rows tool will not be available
ALLOW_DELETE_TOOLS=false
